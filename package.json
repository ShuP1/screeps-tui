{
  "name": "screeps-tui",
  "version": "2.0.4",
  "description": "Terminal interface for the screeps bot programming game",
  "keywords": [
    "client",
    "console",
    "maps",
    "screeps",
    "terminal",
    "tui"
  ],
  "license": "MIT",
  "author": "ShuP1",
  "repository": {
    "type": "git",
    "url": "https://github.com/shup1/screeps-tui.git"
  },
  "bin": {
    "screeps-tui": "./bin/screeps-tui"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "prepublishOnly": "bun run release.ts && exit 1",
    "dev": "bun run --conditions=browser ./src/index.ts",
    "lint": "oxlint --type-check --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun --run fmt:check && bun --run lint"
  },
  "dependencies": {
    "@opentui/core": "^0.1.100",
    "@opentui/solid": "^0.1.100",
    "cac": "^7.0.0",
    "screeps-api": "npm:@screepts/screeps-api@^1.1.1",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@tsconfig/bun": "latest",
    "@types/bun": "latest",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.17.4"
  },
  "packageManager": "bun@1.3.10"
}
